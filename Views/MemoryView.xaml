<UserControl x:Class="MemGuard.Views.MemoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MemGuard.Controls"
             xmlns:helpers="clr-namespace:MemGuard.Helpers"
             xmlns:loc="clr-namespace:MemGuard.Localization"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="{loc:Loc Key=Memory.Kicker}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="Bold" FontFamily="{StaticResource MainFont}"/>
                <TextBlock Text="{loc:Loc Key=Memory.Title}" Foreground="{StaticResource TextWhiteBrush}" FontSize="24" FontWeight="Bold" Margin="0,4,0,0" FontFamily="{StaticResource MainFont}"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource BorderDarkBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <controls:CircularHealthGauge Grid.Row="0"
                                                      Value="{Binding UsagePercentage}"
                                                      Width="220"
                                                      Height="220"
                                                      HorizontalAlignment="Center"
                                                      Margin="0,0,0,24" />

                        <StackPanel Grid.Row="1" Margin="0,0,0,24">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc Key=Memory.TotalRam}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" FontFamily="{StaticResource MainFont}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalMemory}" Foreground="{StaticResource TextWhiteBrush}" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Right" FontFamily="{StaticResource MainFont}"/>
                            </Grid>
                            <Separator Background="{StaticResource BorderDarkBrush}" Height="1" Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc Key=Memory.UsedMemory}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" FontFamily="{StaticResource MainFont}"/>
                                <TextBlock Grid.Column="1" Text="{Binding UsedMemory}" Foreground="{StaticResource TextWhiteBrush}" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Right" FontFamily="{StaticResource MainFont}"/>
                            </Grid>
                            <Separator Background="{StaticResource BorderDarkBrush}" Height="1" Margin="0,0,0,10" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc Key=Memory.AvailableMemory}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" FontFamily="{StaticResource MainFont}"/>
                                <TextBlock Grid.Column="1" Text="{Binding AvailableMemory}" Foreground="{StaticResource ElectricBlueBrush}" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Right" FontFamily="{StaticResource MainFont}"/>
                            </Grid>
                        </StackPanel>

                        <Button Grid.Row="2"
                                Style="{StaticResource PrimaryButton}"
                                Content="{loc:Loc Key=Memory.Optimize}"
                                Command="{Binding OptimizeCommand}"
                                IsEnabled="{Binding IsOptimizing, Converter={StaticResource InverseBooleanConverter}}"
                                HorizontalAlignment="Stretch"
                                Height="46"
                                Margin="0,4,0,0" />
                    </Grid>
                </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource ConsoleBgBrush}"
                            BorderBrush="{StaticResource BorderDarkBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="{loc:Loc Key=Memory.Log}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource MainFont}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12" />

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding StatusLog}"
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontFamily="Consolas, Courier New, monospace"
                                           FontSize="12"
                                           LineHeight="20"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{StaticResource SuccessSurfaceBrush}"
                            BorderBrush="{StaticResource SuccessBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,14"
                            Visibility="{Binding ShowResult, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Path Grid.Column="0"
                                  Data="M12,2A10,10 0 1,0 22,12A10,10 0 0,0 12,2M10,17L5,12L6.41,10.59L10,14.17L17.59,6.58L19,8L10,17Z"
                                  Fill="{StaticResource SuccessBrush}"
                                  Width="28"
                                  Height="28"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="0,0,16,0" />

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc Key=Memory.Success}"
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontWeight="Bold"
                                           FontSize="12.5"
                                           FontFamily="{StaticResource MainFont}"/>
                                <TextBlock Text="{Binding ResultText}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,0,0"
                                           FontFamily="{StaticResource MainFont}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>

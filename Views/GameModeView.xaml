<UserControl x:Class="MemGuard.Views.GameModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helpers="clr-namespace:MemGuard.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="GAME MODE" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="Bold" FontFamily="{StaticResource MainFont}"/>
            <TextBlock Text="High-Performance Optimization" Foreground="{StaticResource TextWhiteBrush}" FontSize="24" FontWeight="Bold" Margin="0,4,0,0" FontFamily="{StaticResource MainFont}"/>
        </StackPanel>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Game Mode Toggles Column (Left) -->
            <Border Grid.Column="0"
                    Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource BorderDarkBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Neon Game Mode Badge Indicator -->
                    <Grid Grid.Row="0" Margin="0,20,0,32">
                        <!-- Glow Layer when ON -->
                        <Border x:Name="GlowBorder"
                                Height="84"
                                Width="260"
                                Background="{StaticResource SuccessSurfaceBrush}"
                                BorderBrush="{StaticResource SuccessBrush}"
                                BorderThickness="2"
                                CornerRadius="42"
                                Visibility="{Binding IsGameModeActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border.Effect>
                                <BlurEffect Radius="15" />
                            </Border.Effect>
                        </Border>

                        <!-- Display Badge -->
                        <Border Height="84"
                                Width="260"
                                CornerRadius="42"
                                BorderThickness="2"
                                VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource CardAltBgBrush}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderDarkBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGameModeActive}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SuccessSurfaceBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="GAME MODE"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"

                                           HorizontalAlignment="Center" />
                                <TextBlock FontSize="24"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="INACTIVE" />
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGameModeActive}" Value="True">
                                                    <Setter Property="Text" Value="ACTIVE" />
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Explanations -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,24">
                        <TextBlock Text="SYSTEM ADJUSTMENT" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="Bold" FontFamily="{StaticResource MainFont}"/>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource TextWhiteBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   LineHeight="20"
                                   Margin="0,6,0,0"
                                   FontFamily="{StaticResource MainFont}"/>
                    </StackPanel>

                    <!-- Toggle Button in card -->
                    <Grid Grid.Row="3" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Game Mode Switch" Foreground="{StaticResource TextWhiteBrush}" FontWeight="Bold" FontSize="13.5" FontFamily="{StaticResource MainFont}" />
                            <TextBlock Text="Activate game mode profile manually" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0" FontFamily="{StaticResource MainFont}" />
                        </StackPanel>

                        <ToggleButton Grid.Column="1"
                                      Style="{StaticResource ToggleSwitch}"
                                      IsChecked="{Binding IsGameModeActive}"
                                      VerticalAlignment="Center" />
                    </Grid>
                </Grid>
            </Border>

            <!-- Heavy Background Apps Column (Right) -->
            <Border Grid.Column="2"
                    Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource BorderDarkBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="HEAVY USER APPLICATIONS"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   FontWeight="Bold"

                                   FontFamily="{StaticResource MainFont}"/>
                        
                        <Button HorizontalAlignment="Right"
                                Style="{StaticResource ModernButton}"
                                Content="Scan"
                                Padding="8,4"
                                Command="{Binding RefreshAppsCommand}"
                                Height="24"/>
                    </Grid>

                    <!-- Recommendations List -->
                    <ListView Grid.Row="1"
                              ItemsSource="{Binding BackgroundApps}"
                              Background="Transparent"
                              BorderThickness="0"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="0,0,0,1" Padding="0,10" HorizontalAlignment="Stretch">
                                    <Grid Width="360">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextWhiteBrush}" FontWeight="Bold" FontSize="13" FontFamily="{StaticResource MainFont}"/>
                                            <TextBlock Text="{Binding Publisher}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,1,0,0" FontFamily="{StaticResource MainFont}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding MemoryFormatted}"
                                                   Foreground="{StaticResource DangerBrush}"
                                                   FontWeight="Bold"
                                                   FontSize="12.5"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,0"
                                                   FontFamily="{StaticResource MainFont}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Optimization Action -->
                    <Button Grid.Row="2"
                            Style="{StaticResource PrimaryButton}"
                            Content="OPTIMIZE SYSTEM FOR GAMING"
                            Command="{Binding OptimizeGamingCommand}"
                            Height="46"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Stretch" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

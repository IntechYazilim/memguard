<UserControl x:Class="MemGuard.Views.CleanerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helpers="clr-namespace:MemGuard.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="SYSTEM CLEANER" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="Bold" FontFamily="{StaticResource MainFont}"/>
            <TextBlock Text="Safe Storage Optimization" Foreground="{StaticResource TextWhiteBrush}" FontSize="24" FontWeight="Bold" Margin="0,4,0,0" FontFamily="{StaticResource MainFont}"/>
        </StackPanel>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- Left Column: Checkbox list of categories -->
            <Border Grid.Column="0"
                    Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource BorderDarkBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="CLEANING CATEGORIES"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               FontWeight="Bold"

                               Margin="0,0,0,16"
                               FontFamily="{StaticResource MainFont}"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderDarkBrush}" BorderThickness="0,0,0,1" Padding="0,12" Margin="0,0,8,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Toggle Checkbox -->
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,14,0"
                                                      Command="{Binding DataContext.ScanCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}" />

                                            <!-- Label & Description -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextWhiteBrush}" FontWeight="Bold" FontSize="13.5" FontFamily="{StaticResource MainFont}" />
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap" FontFamily="{StaticResource MainFont}" />
                                            </StackPanel>

                                            <!-- Status / Size -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Status}"
                                                       Foreground="{StaticResource ElectricBlueBrush}"
                                                       FontWeight="Bold"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"
                                                       Margin="12,0,0,0"
                                                       FontFamily="{StaticResource MainFont}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right Column: Optimization Actions & Stats -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Actions card -->
                <Border Grid.Row="0"
                        Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource BorderDarkBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="24"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="SCAN RESULTS"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   FontWeight="Bold"

                                   FontFamily="{StaticResource MainFont}"/>

                        <!-- Big space counter -->
                        <StackPanel Grid.Row="1" Margin="0,16,0,24">
                            <TextBlock Text="{Binding CleanableSizeText}"
                                       Foreground="{StaticResource ElectricBlueBrush}"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       FontFamily="{StaticResource MainFont}"/>
                            <TextBlock Text="Total Cleanable Space"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"
                                       Margin="0,2,0,0"
                                       FontFamily="{StaticResource MainFont}"/>
                        </StackPanel>

                        <!-- Clean explanation -->
                        <TextBlock Grid.Row="2"
                                   Text="MemGuard will safely delete temp folders, caches, and recycle bin items. Browser passwords and history will remain untouched."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11.5"
                                   TextWrapping="Wrap"
                                   LineHeight="18"
                                   FontFamily="{StaticResource MainFont}" />

                        <!-- Buttons panel -->
                        <StackPanel Grid.Row="3">
                            <Button Style="{StaticResource ModernButton}"
                                    Content="SCAN SYSTEM"
                                    Command="{Binding ScanCommand}"
                                    IsEnabled="{Binding IsCleaning, Converter={StaticResource InverseBooleanConverter}}"
                                    Height="40"
                                    Margin="0,0,0,10" />
                            
                            <Button Style="{StaticResource PrimaryButton}"
                                    Content="CLEAN SYSTEM"
                                    Command="{Binding CleanCommand}"
                                    IsEnabled="{Binding IsCleaning, Converter={StaticResource InverseBooleanConverter}}"
                                    Height="44" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Clean Summary card -->
                <Border Grid.Row="1"
                        Background="{StaticResource SuccessSurfaceBrush}"
                        BorderBrush="{StaticResource SuccessBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,12"
                        Visibility="{Binding ShowCleanedResult, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Path Data="M12,2A10,10 0 1,0 22,12A10,10 0 0,0 12,2M10,17L5,12L6.41,10.59L10,14.17L17.59,6.58L19,8L10,17Z"
                              Fill="{StaticResource SuccessBrush}"
                              Width="24"
                              Height="24"
                              Stretch="Uniform"
                              Margin="0,0,12,0"
                              VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="CLEAN COMPLETE"
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontWeight="Bold"
                                       FontSize="12"

                                       FontFamily="{StaticResource MainFont}"/>
                            <TextBlock Text="{Binding CleanedResultText}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="11.5"
                                       Margin="0,2,0,0"
                                       FontFamily="{StaticResource MainFont}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

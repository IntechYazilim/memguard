<UserControl x:Class="MemGuard.Views.ProcessesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:MemGuard.Helpers"
             xmlns:loc="clr-namespace:MemGuard.Localization"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">
    <UserControl.Resources>
        <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="{loc:Loc Key=Processes.Kicker}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           FontWeight="Bold"
                           FontFamily="{StaticResource MainFont}" />
                <TextBlock Text="{loc:Loc Key=Processes.Title}"
                           Foreground="{StaticResource TextWhiteBrush}"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,4,0,0"
                           FontFamily="{StaticResource MainFont}" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="140" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Search processes..."
                         Margin="0,0,12,0"
                         Height="38"
                         VerticalContentAlignment="Center" />

                <ComboBox Grid.Column="1"
                          Height="38"
                          SelectedValuePath="Tag"
                          SelectedValue="{Binding SortBy}"
                          VerticalContentAlignment="Center">
                    <ComboBoxItem Tag="Memory"
                                  Content="{loc:Loc Key=Processes.SortMemory}"
                                  IsSelected="True" />
                    <ComboBoxItem Tag="Cpu"
                                  Content="{loc:Loc Key=Processes.SortCpu}" />
                </ComboBox>
            </Grid>
        </Grid>

        <Grid Grid.Row="1"
              Margin="0,0,0,16"
              Visibility="{Binding HighMemoryApps.Count, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{loc:Loc Key=Processes.HighMemory}"
                       Foreground="{StaticResource WarningBrush}"
                       FontSize="10.5"
                       FontWeight="Bold"
                       Margin="0,0,0,8"
                       FontFamily="{StaticResource MainFont}" />

            <ItemsControl Grid.Row="1" ItemsSource="{Binding HighMemoryApps}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardAltBgBrush}"
                                BorderBrush="{StaticResource DangerBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14,10"
                                Width="260"
                                Margin="0,0,12,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{StaticResource TextWhiteBrush}"
                                               FontWeight="Bold"
                                               FontSize="13"
                                               FontFamily="{StaticResource MainFont}" />
                                    <TextBlock Text="{Binding MemoryFormatted}"
                                               Foreground="{StaticResource DangerBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="11"
                                               Margin="0,2,0,0"
                                               FontFamily="{StaticResource MainFont}" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Style="{StaticResource ModernButton}"
                                        Content="{loc:Loc Key=Processes.CloseApp}"
                                        Padding="10,6"
                                        Command="{Binding DataContext.TerminateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        BorderBrush="{StaticResource DangerBrush}"
                                        Foreground="{StaticResource DangerBrush}"
                                        Height="30"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource BorderDarkBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="4"
                    Margin="0,0,20,0">
                <Grid>
                    <ListView ItemsSource="{Binding Processes}"
                              SelectedItem="{Binding SelectedProcess}"
                              Background="Transparent"
                              BorderThickness="0"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{loc:Loc Key=Processes.Application}" Width="190">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="4,0,0,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextWhiteBrush}"
                                                           FontFamily="{StaticResource MainFont}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="PID" DisplayMemberBinding="{Binding Id}" Width="72" />
                                <GridViewColumn Header="{loc:Loc Key=Processes.RamUsage}" DisplayMemberBinding="{Binding MemoryFormatted}" Width="100" />
                                <GridViewColumn Header="{loc:Loc Key=Processes.CpuUsage}" DisplayMemberBinding="{Binding CpuUsage, StringFormat={}{0:F1}%}" Width="72" />
                                <GridViewColumn Header="{loc:Loc Key=Processes.Publisher}" DisplayMemberBinding="{Binding Publisher}" Width="150" />
                                <GridViewColumn Header="{loc:Loc Key=Processes.Status}" DisplayMemberBinding="{Binding Status}" Width="130" />
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Border Background="#A0070A13"
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                            CornerRadius="10">
                        <TextBlock Text="{loc:Loc Key=Processes.Loading}"
                                   Foreground="{StaticResource ElectricBlueBrush}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource MainFont}" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Width="320"
                    Background="{StaticResource SidebarBgBrush}"
                    BorderBrush="{StaticResource BorderDarkBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Visibility="{Binding ShowDetails, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="{loc:Loc Key=Processes.ProcessDetails}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource MainFont}" />
                        <Button HorizontalAlignment="Right"
                                Command="{Binding CloseDetailsCommand}"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                          Fill="{StaticResource TextSecondaryBrush}"
                                          Width="12"
                                          Height="12"
                                          Stretch="Uniform" />
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Key=Processes.ProcessName}" Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" FontFamily="{StaticResource MainFont}" />
                            <TextBlock Text="{Binding SelectedProcess.Name}" Foreground="{StaticResource TextWhiteBrush}" FontSize="16" FontWeight="Bold" Margin="0,2,0,16" TextTrimming="CharacterEllipsis" FontFamily="{StaticResource MainFont}" />

                            <TextBlock Text="PID" Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" FontFamily="{StaticResource MainFont}" />
                            <TextBlock Text="{Binding SelectedProcess.Id}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13.5" FontWeight="SemiBold" Margin="0,2,0,16" FontFamily="{StaticResource MainFont}" />

                            <TextBlock Text="{loc:Loc Key=Processes.Publisher}" Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" FontFamily="{StaticResource MainFont}" />
                            <TextBlock Text="{Binding SelectedProcess.Publisher}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13.5" FontWeight="SemiBold" Margin="0,2,0,16" TextWrapping="Wrap" FontFamily="{StaticResource MainFont}" />

                            <TextBlock Text="{loc:Loc Key=Processes.RamUsage}" Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" FontFamily="{StaticResource MainFont}" />
                            <TextBlock Text="{Binding SelectedProcess.MemoryFormatted}" Foreground="{StaticResource ElectricBlueBrush}" FontSize="14.5" FontWeight="Bold" Margin="0,2,0,16" FontFamily="{StaticResource MainFont}" />

                            <TextBlock Text="{loc:Loc Key=Processes.CpuUsage}" Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" FontFamily="{StaticResource MainFont}" />
                            <TextBlock Text="{Binding SelectedProcess.CpuUsage, StringFormat={}{0:F1}%}" Foreground="{StaticResource NeonPurpleBrush}" FontSize="14.5" FontWeight="Bold" Margin="0,2,0,16" FontFamily="{StaticResource MainFont}" />

                            <TextBlock Text="{loc:Loc Key=Processes.Status}" Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" FontFamily="{StaticResource MainFont}" />
                            <TextBlock Text="{Binding SelectedProcess.Status}" Foreground="{StaticResource WarningBrush}" FontSize="13.5" FontWeight="SemiBold" Margin="0,2,0,16" FontFamily="{StaticResource MainFont}" />

                            <TextBlock Text="{loc:Loc Key=Processes.StartTime}" Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" FontFamily="{StaticResource MainFont}" />
                            <TextBlock Text="{Binding SelectedProcess.StartTime}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13.5" FontWeight="SemiBold" Margin="0,2,0,16" FontFamily="{StaticResource MainFont}" />

                            <TextBlock Text="{loc:Loc Key=Processes.ExecutablePath}" Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" FontFamily="{StaticResource MainFont}" />
                            <TextBlock Text="{Binding SelectedProcess.ExecutablePath}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11.5" TextWrapping="Wrap" FontFamily="{StaticResource MainFont}" />
                        </StackPanel>
                    </ScrollViewer>

                    <Button Grid.Row="2"
                            Style="{StaticResource PrimaryButton}"
                            Background="{StaticResource DangerBrush}"
                            Content="{loc:Loc Key=Processes.CloseApplication}"
                            Command="{Binding TerminateCommand}"
                            Height="42"
                            HorizontalAlignment="Stretch" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

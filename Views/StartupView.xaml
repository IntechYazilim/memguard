<UserControl x:Class="MemGuard.Views.StartupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:MemGuard.Helpers"
             xmlns:loc="clr-namespace:MemGuard.Localization"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helpers:ImpactColorConverter x:Key="ImpactColorConverter" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="{loc:Loc Key=Startup.Kicker}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="Bold" FontFamily="{StaticResource MainFont}"/>
            <TextBlock Text="{loc:Loc Key=Startup.Title}" Foreground="{StaticResource TextWhiteBrush}" FontSize="24" FontWeight="Bold" Margin="0,4,0,0" FontFamily="{StaticResource MainFont}"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource CardAltBgBrush}"
                BorderBrush="{StaticResource BorderDarkBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="18"
                Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{loc:Loc Key=Startup.InfoTitle}"
                               Foreground="{StaticResource TextWhiteBrush}"
                               FontSize="16"
                               FontWeight="Bold"
                               FontFamily="{StaticResource MainFont}" />
                    <TextBlock Text="{loc:Loc Key=Startup.InfoDesc}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,6,24,0"
                               FontFamily="{StaticResource MainFont}" />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="{StaticResource SidebarBgBrush}"
                        BorderBrush="{StaticResource BorderDarkBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="{Binding StartupItems.Count}"
                                   Foreground="{StaticResource TextWhiteBrush}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   FontFamily="{StaticResource MainFont}" />
                        <TextBlock Text="{loc:Loc Key=Startup.Tracked}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   FontFamily="{StaticResource MainFont}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource CardBgBrush}"
                BorderBrush="{StaticResource BorderDarkBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="10">
            <Grid>
                <ListView ItemsSource="{Binding StartupItems}"
                          Background="Transparent"
                          BorderThickness="0"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="{loc:Loc Key=Startup.Status}" Width="76">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ToggleButton Style="{StaticResource ToggleSwitch}"
                                                      IsChecked="{Binding IsEnabled}"
                                                      Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="{loc:Loc Key=Startup.Application}" Width="220">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{StaticResource TextWhiteBrush}" FontFamily="{StaticResource MainFont}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="{loc:Loc Key=Startup.Publisher}" Width="180">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Publisher}" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource MainFont}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="{loc:Loc Key=Startup.Location}" Width="220">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Location}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" FontFamily="{StaticResource MainFont}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="{loc:Loc Key=Startup.Impact}" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8"
                                                Padding="8,4"
                                                Background="{Binding Impact, Converter={StaticResource ImpactColorConverter}, ConverterParameter=bg}"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Impact}"
                                                       Foreground="{Binding Impact, Converter={StaticResource ImpactColorConverter}, ConverterParameter=fg}"
                                                       FontWeight="Bold"
                                                       FontSize="11"
                                                       FontFamily="{StaticResource MainFont}"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Border Background="#A0070A13"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                        CornerRadius="16">
                    <TextBlock Text="{loc:Loc Key=Startup.Loading}"
                               Foreground="{StaticResource ElectricBlueBrush}"
                               FontWeight="Bold"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource MainFont}"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

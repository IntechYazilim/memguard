<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Theme Core Colors -->
    <Color x:Key="BgColor">#070A13</Color>
    <Color x:Key="SidebarBgColor">#0A0F1D</Color>
    <Color x:Key="CardBgColor">#0E1626</Color>
    <Color x:Key="CardHoverBgColor">#131E35</Color>
    <Color x:Key="CardAltBgColor">#121C31</Color>
    <Color x:Key="SidebarSelectedColor">#1F2B40</Color>
    <Color x:Key="SidebarHoverColor">#152033</Color>
    <Color x:Key="ConsoleBgColor">#03060E</Color>
    <Color x:Key="SuccessSurfaceColor">#0D271D</Color>
    
    <!-- Accent Colors -->
    <Color x:Key="ElectricBlueColor">#00F0FF</Color>
    <Color x:Key="NeonPurpleColor">#8B5CF6</Color>
    <Color x:Key="WarningColor">#FBBF24</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="SuccessColor">#10B981</Color>

    <!-- Brush Definitions -->
    <SolidColorBrush x:Key="BgBrush" Color="{DynamicResource BgColor}" />
    <SolidColorBrush x:Key="SidebarBgBrush" Color="{DynamicResource SidebarBgColor}" />
    <SolidColorBrush x:Key="CardBgBrush" Color="{DynamicResource CardBgColor}" />
    <SolidColorBrush x:Key="CardHoverBgBrush" Color="{DynamicResource CardHoverBgColor}" />
    <SolidColorBrush x:Key="CardAltBgBrush" Color="{DynamicResource CardAltBgColor}" />
    <SolidColorBrush x:Key="SidebarSelectedBrush" Color="{DynamicResource SidebarSelectedColor}" />
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{DynamicResource SidebarHoverColor}" />
    <SolidColorBrush x:Key="ConsoleBgBrush" Color="{DynamicResource ConsoleBgColor}" />
    <SolidColorBrush x:Key="SuccessSurfaceBrush" Color="{DynamicResource SuccessSurfaceColor}" />
    
    <SolidColorBrush x:Key="ElectricBlueBrush" Color="{DynamicResource ElectricBlueColor}" />
    <SolidColorBrush x:Key="NeonPurpleBrush" Color="{DynamicResource NeonPurpleColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{DynamicResource DangerColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}" />

    <!-- Typography Brushes -->
    <Color x:Key="TextWhiteColor">#FFFFFF</Color>
    <Color x:Key="TextPrimaryColor">#F3F4F6</Color>
    <Color x:Key="TextSecondaryColor">#9CA3AF</Color>
    <Color x:Key="TextMutedColor">#6B7280</Color>
    <Color x:Key="TextLightBlueColor">#A5F3FC</Color>

    <SolidColorBrush x:Key="TextWhiteBrush" Color="{DynamicResource TextWhiteColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{DynamicResource TextMutedColor}" />
    <SolidColorBrush x:Key="TextLightBlueBrush" Color="{DynamicResource TextLightBlueColor}" />

    <!-- Gradient Brushes -->
    <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{DynamicResource ElectricBlueColor}" Offset="0.0" />
        <GradientStop Color="{DynamicResource NeonPurpleColor}" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GlowGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#2200F0FF" Offset="0" />
        <GradientStop Color="#00000000" Offset="1" />
    </LinearGradientBrush>

    <!-- Border Brushes -->
    <Color x:Key="BorderDarkColor">#1E293B</Color>
    <Color x:Key="BorderLightColor">#334155</Color>
    <Color x:Key="BorderGlowColor">#4400F0FF</Color>
    <SolidColorBrush x:Key="BorderDarkBrush" Color="{DynamicResource BorderDarkColor}" />
    <SolidColorBrush x:Key="BorderLightBrush" Color="{DynamicResource BorderLightColor}" />
    <SolidColorBrush x:Key="BorderGlowBrush" Color="{DynamicResource BorderGlowColor}" />

    <!-- Fonts -->
    <FontFamily x:Key="MainFont">Segoe UI, Inter, Roboto, Helvetica, Arial</FontFamily>
    
</ResourceDictionary>

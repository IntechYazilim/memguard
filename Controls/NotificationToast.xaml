<UserControl x:Class="MemGuard.Controls.NotificationToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             HorizontalAlignment="Right"
             VerticalAlignment="Bottom"
             Margin="0,0,24,24"
             Visibility="Collapsed"
             Width="320">
    
    <UserControl.Resources>
        <!-- Slide and fade in animation -->
        <Storyboard x:Key="ShowStoryboard">
            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Visibility)">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}" />
            </ObjectAnimationUsingKeyFrames>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.0" To="1.0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="50" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Slide and fade out animation -->
        <Storyboard x:Key="HideStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.0" Duration="0:0:0.2" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="30" Duration="0:0:0.2" />
            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Visibility)"
                                           BeginTime="0:0:0.2">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}" />
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.RenderTransform>
        <TranslateTransform />
    </UserControl.RenderTransform>

    <!-- Notification Window Container -->
    <Grid>
        <!-- Shadow backdrop -->
        <Border Background="{DynamicResource SidebarBgBrush}"
                BorderBrush="{DynamicResource BorderDarkBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="3" Opacity="0.5" />
            </Border.Effect>
        </Border>

        <!-- Main Card Grid -->
        <Border x:Name="ColorIndicatorBorder"
                Background="{DynamicResource CardBgBrush}"
                BorderThickness="3,0,0,0"
                BorderBrush="{StaticResource ElectricBlueBrush}"
                CornerRadius="8"
                Padding="16,12">
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Icon Column -->
                <Grid x:Name="IconGrid" Margin="0,0,12,0" VerticalAlignment="Top">
                    <!-- Info Icon -->
                    <Path x:Name="IconInfo" Data="M9,2A7,7 0 1,1 2,9A7,7 0 0,1 9,2M9,4A5,5 0 1,0 14,9A5,5 0 0,0 9,4M8,7H10V9H8V7M8,11H10V15H8V11Z" Fill="{StaticResource ElectricBlueBrush}" Width="20" Height="20" Stretch="Uniform" Visibility="Visible" />
                    <!-- Success Icon -->
                    <Path x:Name="IconSuccess" Data="M12,2A10,10 0 1,0 22,12A10,10 0 0,0 12,2M10,17L5,12L6.41,10.59L10,14.17L17.59,6.58L19,8L10,17Z" Fill="{StaticResource SuccessBrush}" Width="20" Height="20" Stretch="Uniform" Visibility="Collapsed" />
                    <!-- Warning Icon -->
                    <Path x:Name="IconWarning" Data="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z" Fill="{StaticResource WarningBrush}" Width="20" Height="20" Stretch="Uniform" Visibility="Collapsed" />
                    <!-- Error Icon -->
                    <Path x:Name="IconError" Data="M12,2C17.52,2 22,6.48 22,12C22,17.52 17.52,22 12,22C6.48,22 2,17.52 2,12C2,6.48 6.48,2 12,2M15,13H9V15H15V13M15,9H9V11H15V9Z" Fill="{StaticResource DangerBrush}" Width="20" Height="20" Stretch="Uniform" Visibility="Collapsed" />
                </Grid>

                <!-- Content Column -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText"
                               Text="Notification Title"
                               Foreground="{DynamicResource TextWhiteBrush}"
                               FontWeight="Bold"
                               FontSize="13"
                               FontFamily="{StaticResource MainFont}"/>
                    <TextBlock x:Name="MessageText"
                               Text="Detailed system update or warning message goes here."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11.5"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"
                               FontFamily="{StaticResource MainFont}"/>
                </StackPanel>

                <!-- Close Button -->
                <Button Grid.Column="2"
                        Width="20"
                        Height="20"
                        VerticalAlignment="Top"
                        Margin="8,0,0,0"
                        Cursor="Hand"
                        Click="Close_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid Background="Transparent">
                                <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Fill="{DynamicResource TextMutedBrush}" Width="10" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
